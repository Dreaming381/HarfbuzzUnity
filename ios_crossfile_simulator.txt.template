[binaries]
c = 'clang'
cpp = 'clang++'
objc = 'clang'
objcpp = 'clang++'
ar = 'ar'
strip = 'strip'
ranlib = 'ranlib'
size = 'size'
codesign = 'codesign'

[host_machine]
system = 'ios'
cpu_family = 'aarch64'
cpu = 'arm64'
endian = 'little'

[constants]
sdk_path = '/Applications/Xcode.app/Contents/Developer/Platforms/iPhoneSimulator.platform/Developer/SDKs/iPhoneSimulator.sdk'
ROOT = '${MESON_SOURCE_ROOT}'

[properties]
# essential for simulator builds
needs_exe_wrapper = true

[built-in options]
c_args = ['-mios-simulator-version-min=13.0', '-arch', 'arm64', '-isysroot', sdk_path]
cpp_args = ['-mios-simulator-version-min=13.0', '-arch', 'arm64', '-isysroot', sdk_path]
c_link_args = ['-mios-simulator-version-min=13.0', '-arch', 'arm64', '-isysroot', sdk_path]
cpp_link_args = ['-mios-simulator-version-min=13.0', '-arch', 'arm64', '-isysroot', sdk_path]
default_library = 'static'